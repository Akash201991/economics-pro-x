<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE html>

<html
    b:version='2'
    expr:dir='data:blog.languageDirection'
    expr:lang='data:blog.locale'
    xmlns='http://www.w3.org/1999/xhtml'
    xmlns:b='http://www.google.com/2005/gml/b'
    xmlns:data='http://www.google.com/2005/gml/data'
    xmlns:expr='http://www.google.com/2005/gml/expr'>

<head>

<meta charset='UTF-8'/>

<meta content='width=device-width, initial-scale=1'
      name='viewport'/>

<title><data:blog.pageTitle/></title>

<meta expr:content='data:blog.metaDescription'
      name='description'/>

<link expr:href='data:blog.canonicalUrl'
      rel='canonical'/>

<b:include data='blog' name='all-head-content'/>

<b:skin><![CDATA[

{{CSS}}

]]></b:skin>

</head>

<body>

<div id='app'>

<header id='header'>

<!-- Header -->

</header>

<nav id='navigation'>

<!-- Navigation -->

</nav>

<section id='hero'>

<!-- Hero -->

</section>

<main id='content'>

<b:section
    id='main'
    showaddelement='yes'
    maxwidgets='1'/>

</main>

<aside id='sidebar'>

<b:section
    id='sidebar'
    showaddelement='yes'
    maxwidgets='10'/>

</aside>

<footer id='footer'>

<!-- Footer -->

</footer>

</div>

<b:include data='blog' name='google-analytics'/>

<script><![CDATA[

{{JS}}

]]></script>

</body>

</html>